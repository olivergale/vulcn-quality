{
  "name": "@vulcn/quality",
  "version": "0.1.0",
  "private": true,
  "description": "Vulcn quality plane — composable, reusable QC surfaces + project tiers. Consumed at arm's length by any Vulcn project plane.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./tiers": "./src/tiers/index.ts",
    "./runner": "./src/runner/index.ts",
    "./surfaces/web-smoke": "./src/surfaces/web-smoke/index.ts",
    "./surfaces/hygiene": "./src/surfaces/hygiene/index.ts",
    "./surfaces/worker-contract": "./src/surfaces/worker-contract/index.ts",
    "./surfaces/a11y": "./src/surfaces/a11y/index.ts",
    "./surfaces/visual": "./src/surfaces/visual/index.ts",
    "./surfaces/perf": "./src/surfaces/perf/index.ts",
    "./surfaces/fan-out-review": "./src/surfaces/fan-out-review/index.ts",
    "./surfaces/module-contract": "./src/surfaces/module-contract/index.ts"
  },
  "bin": {
    "module-contract": "./src/surfaces/module-contract/cli.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@axe-core/playwright": ">=4.9",
    "@playwright/test": ">=1.40"
  },
  "peerDependenciesMeta": {
    "@axe-core/playwright": {
      "optional": true
    },
    "@playwright/test": {
      "optional": true
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@eslint/js": "^9.13.0",
    "@playwright/test": "^1.48.0",
    "@types/node": "^20.16.0",
    "eslint": "^9.13.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.10.0",
    "vitest": "^2.1.0"
  }
}
